# ============================================
# Docker 部署环境变量配置
# 使用方法：复制此文件为 .env 并修改
#   cp .env.example .env
# ============================================

# --- JWT 认证 ---
# 生产环境下请务必修改为强密钥！
JWT_SECRET_KEY=your-strong-secret-key-change-me

# --- 应用设置 ---
DEBUG=false
# APP_ENV=production

# --- 端口映射 ---
# 前端对外端口（默认 80）
FRONTEND_PORT=80
# 后端对外端口（默认 8000，一般不需要直接暴露）
BACKEND_PORT=8000
